# ─── Contact Form Email (Nodemailer) ────────────────────────────────────────
# Messages are delivered to:
#   dr.francis@frandeeconsultingservices.com
#   contact@frandeeconsultingservices.com
#
# Option A — Use your hosting provider's SMTP (cPanel / Plesk / DirectAdmin)
#   SMTP_HOST=mail.frandeeconsultingservices.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=contact@frandeeconsultingservices.com
#   SMTP_PASS=your_email_password
#
# Option B — Google Workspace / Gmail (enable "App Password")
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=contact@frandeeconsultingservices.com
#   SMTP_PASS=your_google_app_password
#
# Option C — Microsoft 365 / Outlook
#   SMTP_HOST=smtp.office365.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=contact@frandeeconsultingservices.com
#   SMTP_PASS=your_password

SMTP_HOST=mail.frandeeconsultingservices.com
SMTP_PORT=587
SMTP_SECURE=false
