NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_SITE_URL=https://frandeeconsultingservices.com
NEXT_PUBLIC_SITE_NAME=Frandee Geoscience

# Contact Form Email (Nodemailer)
# Add these same variables in Vercel Project Settings -> Environment Variables.
# Messages are delivered to:
#   dr.francis@frandeeconsultingservices.com
#   services@frandeeconsultingservices.com

# LyteHosting / cPanel SMTP
SMTP_HOST=mail.frandeeconsultingservices.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=services@frandeeconsultingservices.com
SMTP_PASS=your_email_password

# Optional: override the receiver list. Separate multiple addresses with commas.
CONTACT_TO=dr.francis@frandeeconsultingservices.com,services@frandeeconsultingservices.com

# Optional: use if your SMTP provider requires a different verified sender address.
# SMTP_FROM=services@frandeeconsultingservices.com
